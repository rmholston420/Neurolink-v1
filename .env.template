# Neurolink environment configuration template
# Copy to .env and fill in your values

# ── Adapter ───────────────────────────────────────────────────────────────────
# Options: mock | ble | lsl
NEUROLINK_ADAPTER_TYPE=mock

# Options: muse_s_gen1 | muse_s_athena
NEUROLINK_DEVICE_MODEL=muse_s_gen1

# BLE MAC address (required when NEUROLINK_ADAPTER_TYPE=ble)
NEUROLINK_MUSE_BLE_ADDRESS=

# Publish Hz (default 4.0)
NEUROLINK_PUBLISH_HZ=4.0

# ── Database ──────────────────────────────────────────────────────────────────
# Path to SQLite database file (use :memory: for tests)
NEUROLINK_DB_PATH=./data/neurolink.db

# ── Redis ─────────────────────────────────────────────────────────────────────
NEUROLINK_REDIS_URL=redis://localhost:6379/0
NEUROLINK_REDIS_ENABLED=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
NEUROLINK_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Logging ───────────────────────────────────────────────────────────────────
NEUROLINK_LOG_JSON=false
NEUROLINK_LOG_LEVEL=INFO

# ── Auth (optional) ───────────────────────────────────────────────────────────
NEUROLINK_AUTH_ENABLED=false
