# Neurolink Environment Configuration Template
# Copy to .env and fill in values. Never commit .env to git.

# Adapter selection
NEUROLINK_ADAPTER_TYPE=mock          # mock | ble | lsl
NEUROLINK_DEVICE_MODEL=muse_s_gen1   # muse_s_gen1 | muse_s_athena
NEUROLINK_MUSE_BLE_ADDRESS=          # BLE MAC address, required for ble mode

# Redis (optional live state cache)
NEUROLINK_REDIS_URL=redis://localhost:6379/0

# Database
NEUROLINK_DB_PATH=./data/neurolink.db

# CORS
NEUROLINK_CORS_ORIGINS=http://localhost:5173

# Logging
NEUROLINK_LOG_JSON=false

# EEG mode (backward compat)
NEUROLINK_EEG_MODE=ble

# Publish cadence (do not change without DSP review)
NEUROLINK_PUBLISH_HZ=4.0
