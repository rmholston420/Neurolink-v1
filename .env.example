# Neurolink environment configuration example
# Copy to .env and fill in values before running the backend.
# All variables are prefixed with NEUROLINK_.

# ── Adapter ───────────────────────────────────────────────────────────────────
# Which EEG adapter to use.
# Options: mock | ble | lsl
# Use 'mock' for local development — no headset required.
NEUROLINK_ADAPTER_TYPE=mock

# Device model identifier.
# Options: muse_s_gen1 | muse_s_athena | mock
NEUROLINK_DEVICE_MODEL=muse_s_gen1

# BLE MAC address of the Muse headset.
# Required only when NEUROLINK_ADAPTER_TYPE=ble.
# Find it with: hcitool scan  (Linux) or muselsl list  (cross-platform)
NEUROLINK_MUSE_BLE_ADDRESS=

# SSE publish rate in Hz. Default: 4.0
# Increase to 10 for smoother real-time charts; decrease to reduce CPU.
NEUROLINK_PUBLISH_HZ=4.0

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite session-log database.
# The directory is created automatically on startup.
# Use :memory: in tests for a fresh, isolated in-memory DB.
NEUROLINK_DB_PATH=./data/neurolink.db

# ── Redis (optional) ──────────────────────────────────────────────────────────
# Redis is optional. Set NEUROLINK_REDIS_ENABLED=true if you want
# distributed caching (e.g., multi-worker deployments).
NEUROLINK_REDIS_URL=redis://localhost:6379/0
NEUROLINK_REDIS_ENABLED=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add your deployed frontend URL here for production.
NEUROLINK_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Logging ───────────────────────────────────────────────────────────────────
# NEUROLINK_LOG_JSON=true emits structured JSON logs (recommended for prod).
# NEUROLINK_LOG_LEVEL controls verbosity: DEBUG | INFO | WARNING | ERROR
NEUROLINK_LOG_JSON=false
NEUROLINK_LOG_LEVEL=INFO

# ── Auth (optional) ───────────────────────────────────────────────────────────
# Set to true to enable bearer-token authentication on all API routes.
# When enabled, set NEUROLINK_AUTH_SECRET to a strong random string.
NEUROLINK_AUTH_ENABLED=false
# NEUROLINK_AUTH_SECRET=change-me-to-a-strong-random-secret
